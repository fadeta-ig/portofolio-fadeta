# Required: create an API key in Resend and configure it in Vercel.
RESEND_API_KEY=

# Destination for every consultation brief.
CONTACT_TO_EMAIL=fadeta287@gmail.com

# The default Resend sender works only when the recipient matches the Resend account email.
# For production, verify a domain and replace this with e.g. Gandiva Labs <brief@gandivalabs.my.id>.
CONTACT_FROM_EMAIL="Gandiva Labs <onboarding@resend.dev>"

# Optional comma-separated origins. Leave empty to enforce the request host automatically.
ALLOWED_ORIGIN=

# Recommended for production: create a free Cloudflare Turnstile widget.
# Configure both values together. Without them, the timing, honeypot, origin,
# idempotency, payload limit, and rate-limit protections remain active.
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
