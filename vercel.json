{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/terima-kasih", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy-Report-Only",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' https://www.googletagmanager.com https://challenges.cloudflare.com; connect-src 'self' https://*.google-analytics.com https://challenges.cloudflare.com; img-src 'self' data: https://*.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://api.fontshare.com; font-src 'self' https://fonts.gstatic.com https://cdn.fontshare.com; frame-src https://challenges.cloudflare.com https://calendar.google.com; upgrade-insecure-requests"
        },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Link", "value": "<https://www.gandivalabs.my.id/>; rel=\"canonical\"" }
      ]
    },
    {
      "source": "/portfolio",
      "headers": [
        { "key": "Link", "value": "<https://www.gandivalabs.my.id/portfolio>; rel=\"canonical\"" }
      ]
    },
    {
      "source": "/solusi/company-profile",
      "headers": [
        { "key": "Link", "value": "<https://www.gandivalabs.my.id/solusi/company-profile>; rel=\"canonical\"" }
      ]
    },
    {
      "source": "/solusi/landing-page",
      "headers": [
        { "key": "Link", "value": "<https://www.gandivalabs.my.id/solusi/landing-page>; rel=\"canonical\"" }
      ]
    },
    {
      "source": "/solusi/toko-online",
      "headers": [
        { "key": "Link", "value": "<https://www.gandivalabs.my.id/solusi/toko-online>; rel=\"canonical\"" }
      ]
    },
    {
      "source": "/solusi/website-custom",
      "headers": [
        { "key": "Link", "value": "<https://www.gandivalabs.my.id/solusi/website-custom>; rel=\"canonical\"" }
      ]
    },
    {
      "source": "/hasil/shinyoung-beauty",
      "headers": [
        { "key": "Link", "value": "<https://www.gandivalabs.my.id/hasil/shinyoung-beauty>; rel=\"canonical\"" }
      ]
    },
    {
      "source": "/hasil/mahakarya-kosmetika",
      "headers": [
        { "key": "Link", "value": "<https://www.gandivalabs.my.id/hasil/mahakarya-kosmetika>; rel=\"canonical\"" }
      ]
    },
    {
      "source": "/hasil/wijaya-inovasi",
      "headers": [
        { "key": "Link", "value": "<https://www.gandivalabs.my.id/hasil/wijaya-inovasi>; rel=\"canonical\"" }
      ]
    },
    {
      "source": "/hasil/karya-teknik-internusa-abadi",
      "headers": [
        { "key": "Link", "value": "<https://www.gandivalabs.my.id/hasil/karya-teknik-internusa-abadi>; rel=\"canonical\"" }
      ]
    },
    {
      "source": "/konsultasi",
      "headers": [
        { "key": "Link", "value": "<https://www.gandivalabs.my.id/konsultasi>; rel=\"canonical\"" }
      ]
    },
    {
      "source": "/privasi",
      "headers": [
        { "key": "Link", "value": "<https://www.gandivalabs.my.id/privasi>; rel=\"canonical\"" }
      ]
    },
    {
      "source": "/terima-kasih",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=3600" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=3600" }
      ]
    }
  ]
}
